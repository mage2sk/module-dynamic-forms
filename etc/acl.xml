<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <!-- Menu Resources under Panth Extensions -->
                <resource id="Panth_Core::panth_extensions">
                    <resource id="Panth_DynamicForms::main" title="Dynamic Forms" sortOrder="30">
                        <resource id="Panth_DynamicForms::form" title="Manage Forms" sortOrder="10"/>
                        <resource id="Panth_DynamicForms::submission" title="Manage Submissions" sortOrder="20"/>
                    </resource>
                </resource>

                <!-- System Configuration Access -->
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="Panth_DynamicForms::config" title="Panth Dynamic Forms Configuration" sortOrder="110"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
