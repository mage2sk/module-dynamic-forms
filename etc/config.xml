<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <panth_dynamicforms>
            <general>
                <enabled>1</enabled>
                <recaptcha_enabled>0</recaptcha_enabled>
                <allowed_file_extensions>jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx</allowed_file_extensions>
                <max_file_size>10</max_file_size>
                <upload_dir>dynamicforms/uploads</upload_dir>
            </general>
            <email>
                <admin_email_template>panth_dynamicforms_email_admin_email_template</admin_email_template>
                <admin_email_sender>general</admin_email_sender>
                <autoreply_email_template>panth_dynamicforms_email_autoreply_email_template</autoreply_email_template>
                <autoreply_email_sender>general</autoreply_email_sender>
            </email>
            <display>
                <form_layout>1column</form_layout>
                <show_form_title>1</show_form_title>
                <show_form_description>1</show_form_description>
                <ajax_submit>1</ajax_submit>
                <loading_text>Submitting...</loading_text>
            </display>
            <styling>
                <use_theme_config>1</use_theme_config>
                <primary_color>#0D9488</primary_color>
                <error_color>#DC2626</error_color>
                <success_color>#16A34A</success_color>
                <border_radius>8px</border_radius>
            </styling>
        </panth_dynamicforms>
    </default>
</config>
