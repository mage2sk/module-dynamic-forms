<script>
function <?= /** @noEscape */ $fid ?>() {
    const cfg = <?= /** @noEscape */ $block->getFormConfig() ?>;
    const fieldsDef = <?= /** @noEscape */ $block->getFieldsJson() ?>;

    return {
        fd: {}, errs: {}, rules: {}, loading: false, success: false,
        successMessage: '', globalError: '', formKey: '',
        files: {}, uploading: {}, uploadProg: {}, dragging: {},

        init() {
            // Get form_key from cookie
            const m = document.cookie.match(/form_key=([^;]+)/);
            this.formKey = m ? m[1] : '';

            // Initialize field values + rules
            fieldsDef.forEach(f => {
                if (f.type === 'checkbox' || f.type === 'multiselect') {
                    this.fd[f.name] = f.default_value ? [f.default_value] : [];
                } else {
                    this.fd[f.name] = f.default_value || '';
                }
                this.errs[f.name] = '';
                this.files[f.name] = null;
                this.uploading[f.name] = false;
                this.uploadProg[f.name] = 0;
                this.dragging[f.name] = false;
                this.rules[f.name] = { required: f.is_required, type: f.type, label: f.label };
            });
        },

        validate(name) {
            const r = this.rules[name];
            if (!r) return true;
            const v = this.fd[name];
            const label = r.label;

            // Required check
            if (r.required) {
                if (r.type === 'file') {
                    if (!this.files[name]) { this.errs[name] = label + ' is required.'; return false; }
                } else if (Array.isArray(v)) {
                    if (v.length === 0) { this.errs[name] = label + ' is required.'; return false; }
                } else if (!v || !String(v).trim()) {
                    this.errs[name] = label + ' is required.'; return false;
                }
            }

            // Type-specific
            if (v && r.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) {
                this.errs[name] = 'Please enter a valid email address.'; return false;
            }
            if (v && r.type === 'phone' && !/^[\d\s\-+().]{7,20}$/.test(v)) {
                this.errs[name] = 'Please enter a valid phone number.'; return false;
            }
            if (v && r.type === 'number' && isNaN(Number(v))) {
                this.errs[name] = 'Please enter a valid number.'; return false;
            }

            this.errs[name] = '';
            return true;
        },

        validateAll() {
            let valid = true;
            fieldsDef.forEach(f => {
                if (f.type !== 'hidden' && !this.validate(f.name)) valid = false;
            });
            return valid;
        },

        async uploadFile(name, file) {
            if (!file) return;
            this.uploading[name] = true;
            this.uploadProg[name] = 0;

            const fd = new FormData();
            fd.append('file', file);
            fd.append('form_key', this.formKey);
            fd.append('field_name', name);

            try {
                const xhr = new XMLHttpRequest();
                xhr.upload.onprogress = (e) => {
                    if (e.lengthComputable) this.uploadProg[name] = Math.round((e.loaded / e.total) * 100);
                };
                const result = await new Promise((resolve, reject) => {
                    xhr.onload = () => resolve(JSON.parse(xhr.responseText));
                    xhr.onerror = () => reject(new Error('Upload failed'));
                    xhr.open('POST', cfg.upload_url);
                    xhr.send(fd);
                });
                if (result.success !== false && (result.file || result.name)) {
                    this.files[name] = { name: file.name, file: result.file || result.name, url: result.url || '' };
                    this.fd[name] = result.file || result.name;
                    this.errs[name] = '';
                } else {
                    this.errs[name] = result.message || 'Upload failed.';
                }
            } catch (e) {
                this.errs[name] = 'Upload failed. Please try again.';
            }
            this.uploading[name] = false;
        },

        removeFile(name) {
            this.files[name] = null;
            this.fd[name] = '';
            if (this.$refs['file_' + name]) this.$refs['file_' + name].value = '';
        },

        async submit() {
            this.globalError = '';
            if (!this.validateAll()) {
                this.globalError = '<?= /* @noEscape */ $escaper->escapeJs(__('Please correct the errors below.')) ?>';
                return;
            }
            this.loading = true;

            const fd = new FormData();
            fd.append('form_key', this.formKey);
            fd.append('form_id', '<?= /* @noEscape */ $formId ?>');
            fieldsDef.forEach(f => {
                const v = this.fd[f.name];
                if (Array.isArray(v)) {
                    v.forEach(item => fd.append(f.name + '[]', item));
                } else {
                    fd.append(f.name, v || '');
                }
            });

            try {
                const resp = await fetch(cfg.submit_url, { method: 'POST', body: fd });
                const data = await resp.json();
                if (data.success) {
                    this.success = true;
                    this.successMessage = data.message || cfg.success_message || '<?= /* @noEscape */ $escaper->escapeJs($successMsg) ?>';
                    if (cfg.redirect_url) setTimeout(() => window.location.href = cfg.redirect_url, 2000);
                } else {
                    if (data.errors) {
                        Object.keys(data.errors).forEach(k => { this.errs[k] = data.errors[k]; });
                    }
                    this.globalError = data.message || '<?= /* @noEscape */ $escaper->escapeJs(__('Something went wrong. Please try again.')) ?>';
                }
            } catch (e) {
                this.globalError = '<?= /* @noEscape */ $escaper->escapeJs(__('Network error. Please try again.')) ?>';
            }
            this.loading = false;
        }
    };
}
</script>
