<script>
(function() {
    var fid = <?= /* @noEscape */ $formId ?>;
    var submitUrl = '<?= /* @noEscape */ $escaper->escapeJs($submitUrl) ?>';
    var uploadUrl = '<?= /* @noEscape */ $escaper->escapeJs($uploadUrl) ?>';
    var successMsg = '<?= /* @noEscape */ $successMsg ?>';
    var redirectUrl = '<?= /* @noEscape */ $escaper->escapeJs($redirectUrl) ?>';
    var form = document.getElementById('pdf-form-' + fid);
    if (!form) return;

    // File upload zones
    form.querySelectorAll('.pdf-drop').forEach(function(zone) {
        var fieldName = zone.dataset.fieldName;
        var fileInput = zone.querySelector('input[type="file"]');
        var hiddenInput = zone.querySelector('input[type="hidden"]');
        zone.addEventListener('click', function() { fileInput.click(); });
        zone.addEventListener('dragover', function(e) { e.preventDefault(); zone.style.borderColor = 'var(--color-primary, #0D9488)'; });
        zone.addEventListener('dragleave', function(e) { e.preventDefault(); zone.style.borderColor = ''; });
        zone.addEventListener('drop', function(e) { e.preventDefault(); zone.style.borderColor = ''; if (e.dataTransfer.files[0]) doUpload(fieldName, e.dataTransfer.files[0]); });
        fileInput.addEventListener('change', function() { if (this.files[0]) doUpload(fieldName, this.files[0]); });

        var fileDisplay = document.getElementById('pdf-file-' + fid + '-' + fieldName);
        if (fileDisplay) {
            fileDisplay.querySelector('.pdf-file-remove').addEventListener('click', function() {
                fileDisplay.style.display = 'none';
                zone.style.display = '';
                hiddenInput.value = '';
            });
        }
    });

    function doUpload(fieldName, file) {
        var zone = document.getElementById('pdf-drop-' + fid + '-' + fieldName);
        var prog = document.getElementById('pdf-prog-' + fid + '-' + fieldName);
        var fileDisp = document.getElementById('pdf-file-' + fid + '-' + fieldName);
        var hidden = zone.querySelector('input[type="hidden"]');
        var bar = prog.querySelector('.pdf-progress-bar');

        prog.classList.add('active');
        bar.style.width = '0%';

        var fd = new FormData();
        fd.append('file', file);
        fd.append('form_key', form.querySelector('[name="form_key"]').value);
        fd.append('field_name', fieldName);

        var xhr = new XMLHttpRequest();
        xhr.upload.onprogress = function(e) { if (e.lengthComputable) bar.style.width = Math.round(e.loaded/e.total*100)+'%'; };
        xhr.onload = function() {
            prog.classList.remove('active');
            try {
                var res = JSON.parse(xhr.responseText);
                if (res.success !== false && (res.file || res.name)) {
                    hidden.value = res.file || res.name;
                    zone.style.display = 'none';
                    fileDisp.style.display = 'flex';
                    fileDisp.querySelector('.pdf-file-name').textContent = file.name;
                    clearError(fieldName);
                } else {
                    showFieldError(fieldName, res.message || 'Upload failed.');
                }
            } catch(e) { showFieldError(fieldName, 'Upload failed.'); }
        };
        xhr.onerror = function() { prog.classList.remove('active'); showFieldError(fieldName, 'Upload failed.'); };
        xhr.open('POST', uploadUrl);
        xhr.send(fd);
    }

    // Validation
    function validateField(el) {
        var name = el.name.replace('[]','');
        var val = el.value.trim();
        var label = el.dataset.label || name;
        var type = el.dataset.type || 'text';
        var req = el.dataset.required === '1';

        if (req && !val) { showFieldError(name, label + ' is required.'); return false; }
        if (val && type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)) { showFieldError(name, 'Please enter a valid email.'); return false; }
        if (val && type === 'phone' && !/^[\d\s\-+().]{7,20}$/.test(val)) { showFieldError(name, 'Please enter a valid phone number.'); return false; }
        clearError(name);
        return true;
    }

    function showFieldError(name, msg) {
        var errEl = document.getElementById('pdf-err-' + fid + '-' + name);
        var fieldEl = form.querySelector('[name="'+name+'"]') || form.querySelector('[name="'+name+'[]"]');
        if (errEl) { errEl.textContent = msg; errEl.classList.add('visible'); }
        if (fieldEl) fieldEl.classList.add('err');
    }
    function clearError(name) {
        var errEl = document.getElementById('pdf-err-' + fid + '-' + name);
        var fieldEl = form.querySelector('[name="'+name+'"]') || form.querySelector('[name="'+name+'[]"]');
        if (errEl) { errEl.textContent = ''; errEl.classList.remove('visible'); }
        if (fieldEl) fieldEl.classList.remove('err');
    }

    // Blur validation
    form.querySelectorAll('.pdf-input,.pdf-textarea,.pdf-select').forEach(function(el) {
        el.addEventListener('blur', function() { validateField(el); });
        el.addEventListener('change', function() { validateField(el); });
    });

    // Submit
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        var globalErr = document.getElementById('pdf-global-err-' + fid);
        var globalErrMsg = document.getElementById('pdf-global-err-msg-' + fid);
        globalErr.classList.remove('visible');

        // Validate all
        var valid = true;
        form.querySelectorAll('[data-required="1"]').forEach(function(el) {
            if (!validateField(el)) valid = false;
        });
        if (!valid) {
            globalErrMsg.textContent = 'Please correct the errors below.';
            globalErr.classList.add('visible');
            return;
        }

        var btn = document.getElementById('pdf-submit-' + fid);
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span> Submitting...';

        var fd = new FormData(form);

        fetch(submitUrl, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    document.getElementById('pdf-form-card-' + fid).style.display = 'none';
                    var sc = document.getElementById('pdf-success-' + fid);
                    sc.classList.add('visible');
                    document.getElementById('pdf-success-msg-' + fid).textContent = data.message || successMsg;
                    if (redirectUrl) setTimeout(function() { window.location.href = redirectUrl; }, 2000);
                } else {
                    if (data.errors) Object.keys(data.errors).forEach(function(k) { showFieldError(k, data.errors[k]); });
                    globalErrMsg.textContent = data.message || 'Something went wrong.';
                    globalErr.classList.add('visible');
                    btn.disabled = false;
                    btn.innerHTML = '<span class="pdf-btn-text">' + '<?= /* @noEscape */ $escaper->escapeJs($btnText) ?>' + '</span>';
                }
            })
            .catch(function() {
                globalErrMsg.textContent = 'Network error. Please try again.';
                globalErr.classList.add('visible');
                btn.disabled = false;
                btn.innerHTML = '<span class="pdf-btn-text">' + '<?= /* @noEscape */ $escaper->escapeJs($btnText) ?>' + '</span>';
            });
    });
})();
</script>
