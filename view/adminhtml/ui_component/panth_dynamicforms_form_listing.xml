<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_dynamicforms_form_listing.panth_dynamicforms_form_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Form</label>
            </button>
        </buttons>
        <spinner>panth_dynamicforms_form_columns</spinner>
        <deps>
            <dep>panth_dynamicforms_form_listing.panth_dynamicforms_form_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="panth_dynamicforms_form_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">form_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Panth_DynamicForms::form</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="panth_dynamicforms_form_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>form_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
        <massaction name="listing_massaction" component="Magento_Ui/js/grid/tree-massactions">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete the selected form(s)?</message>
                        <title translate="true">Delete Forms</title>
                    </confirm>
                    <url path="panth_dynamicforms/form/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
            <action name="enable">
                <settings>
                    <url path="panth_dynamicforms/form/massStatus/status/1"/>
                    <type>enable</type>
                    <label translate="true">Enable</label>
                </settings>
            </action>
            <action name="disable">
                <settings>
                    <url path="panth_dynamicforms/form/massStatus/status/0"/>
                    <type>disable</type>
                    <label translate="true">Disable</label>
                </settings>
            </action>
        </massaction>
    </listingToolbar>

    <columns name="panth_dynamicforms_form_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings>
                <indexField>form_id</indexField>
            </settings>
        </selectionsColumn>

        <column name="form_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>

        <column name="name" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Name</label>
            </settings>
        </column>

        <column name="form_type" component="Magento_Ui/js/grid/columns/select" sortOrder="25">
            <settings>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Type</label>
                <options>
                    <option name="page" xsi:type="array">
                        <item name="value" xsi:type="string">page</item>
                        <item name="label" xsi:type="string" translate="true">Standalone Page</item>
                    </option>
                    <option name="widget" xsi:type="array">
                        <item name="value" xsi:type="string">widget</item>
                        <item name="label" xsi:type="string" translate="true">Widget Only</item>
                    </option>
                    <option name="both" xsi:type="array">
                        <item name="value" xsi:type="string">both</item>
                        <item name="label" xsi:type="string" translate="true">Both</item>
                    </option>
                </options>
            </settings>
        </column>

        <column name="url_key" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">URL Key</label>
            </settings>
        </column>

        <column name="title" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Title</label>
            </settings>
        </column>

        <column name="submission_count" class="Panth\DynamicForms\Ui\Component\Listing\Column\SubmissionCount" sortOrder="45">
            <settings>
                <label translate="true">Submissions</label>
                <sortable>false</sortable>
                <filter>false</filter>
            </settings>
        </column>

        <column name="is_active" component="Magento_Ui/js/grid/columns/select" sortOrder="50">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Active</label>
            </settings>
        </column>

        <column name="store_id" sortOrder="60">
            <settings>
                <filter>text</filter>
                <label translate="true">Store ID</label>
            </settings>
        </column>

        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date" sortOrder="70">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created At</label>
            </settings>
        </column>

        <actionsColumn name="actions" class="Panth\DynamicForms\Ui\Component\Listing\Column\FormActions" sortOrder="200">
            <settings>
                <indexField>form_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
