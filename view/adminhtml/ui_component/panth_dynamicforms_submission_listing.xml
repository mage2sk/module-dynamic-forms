<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_dynamicforms_submission_listing.panth_dynamicforms_submission_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="back">
                <url path="panth_dynamicforms/form/index"/>
                <class>back</class>
                <label translate="true">Back to Forms</label>
            </button>
        </buttons>
        <spinner>panth_dynamicforms_submission_columns</spinner>
        <deps>
            <dep>panth_dynamicforms_submission_listing.panth_dynamicforms_submission_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="panth_dynamicforms_submission_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">submission_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Panth_DynamicForms::submission</aclResource>
        <dataProvider class="Panth\DynamicForms\Ui\DataProvider\SubmissionListingDataProvider"
                      name="panth_dynamicforms_submission_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>submission_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
        <massaction name="listing_massaction" component="Magento_Ui/js/grid/tree-massactions">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete the selected submission(s)?</message>
                        <title translate="true">Delete Submissions</title>
                    </confirm>
                    <url path="panth_dynamicforms/submission/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
            <action name="update_status">
                <settings>
                    <type>update_status</type>
                    <label translate="true">Update Status</label>
                    <actions>
                        <action name="0">
                            <type>new</type>
                            <label translate="true">New</label>
                            <url path="panth_dynamicforms/submission/massStatus/status/new"/>
                        </action>
                        <action name="1">
                            <type>read</type>
                            <label translate="true">Read</label>
                            <url path="panth_dynamicforms/submission/massStatus/status/read"/>
                        </action>
                        <action name="2">
                            <type>replied</type>
                            <label translate="true">Replied</label>
                            <url path="panth_dynamicforms/submission/massStatus/status/replied"/>
                        </action>
                        <action name="3">
                            <type>closed</type>
                            <label translate="true">Closed</label>
                            <url path="panth_dynamicforms/submission/massStatus/status/closed"/>
                        </action>
                    </actions>
                </settings>
            </action>
        </massaction>
    </listingToolbar>

    <columns name="panth_dynamicforms_submission_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings>
                <indexField>submission_id</indexField>
            </settings>
        </selectionsColumn>

        <column name="submission_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>

        <column name="customer_name" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Name</label>
            </settings>
        </column>

        <column name="customer_email" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Email</label>
            </settings>
        </column>

        <column name="status" class="Panth\DynamicForms\Ui\Component\Listing\Column\SubmissionStatus"
                component="Magento_Ui/js/grid/columns/select" sortOrder="40">
            <settings>
                <options class="Panth\DynamicForms\Model\Config\Source\FormStatus"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>

        <column name="customer_ip" sortOrder="50">
            <settings>
                <filter>text</filter>
                <label translate="true">IP Address</label>
            </settings>
        </column>

        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date" sortOrder="60">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Submitted At</label>
            </settings>
        </column>

        <actionsColumn name="actions" class="Panth\DynamicForms\Ui\Component\Listing\Column\SubmissionActions" sortOrder="200">
            <settings>
                <indexField>submission_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
