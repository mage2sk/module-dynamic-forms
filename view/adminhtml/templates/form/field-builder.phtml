 */
$fieldsJson = $block->getFieldsJson();
$fieldTypesJson = $block->getFieldTypesJson();
$fieldWidthsJson = $block->getFieldWidthsJson();
$optionFieldTypes = $block->getOptionFieldTypes();
?>

