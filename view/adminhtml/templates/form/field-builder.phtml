</style>

<div class="df-field-builder" id="df-field-builder">
    <div class="df-field-builder-header">
        <h3><?= $block->escapeHtml(__('Form Fields')) ?></h3>
        <span id="df-field-count" style="color: #666; font-size: 13px;">0 fields</span>
    </div>

    <div class="df-field-list" id="df-field-list">
        <div class="df-empty-state" id="df-empty-state">
            <p><?= $block->escapeHtml(__('No fields added yet. Click the button below to add your first field.')) ?></p>
        </div>
    </div>

    <button type="button" class="df-add-field-btn" id="df-add-field-btn">
        + <?= $block->escapeHtml(__('Add New Field')) ?>
    </button>
</div>

<script>
(function() {
    'use strict';

    var fieldTypes = <?= /* @noEscape */ $fieldTypesJson ?>;
    var fieldWidths = <?= /* @noEscape */ $fieldWidthsJson ?>;
    var optionFieldTypes = <?= /* @noEscape */ $optionFieldTypes ?>;
    var fields = <?= /* @noEscape */ $fieldsJson ?>;
    var fieldIdCounter = 0;
    var draggedItem = null;

    function init() {
        renderFields();
        updateFieldCount();
        bindAddButton();
        syncToHiddenInput();
    }

    function generateTempId() {
        fieldIdCounter++;
        return 'new_' + fieldIdCounter;
    }

    function slugify(text) {
        return text.toLowerCase()
            .replace(/[^a-z0-9\s_-]/g, '')
            .replace(/[\s-]+/g, '_')
            .replace(/^_+|_+$/g, '');
    }

    function renderFields() {
        var list = document.getElementById('df-field-list');
        var emptyState = document.getElementById('df-empty-state');

        // Clear existing items (keep empty state)
        var items = list.querySelectorAll('.df-field-item');
        items.forEach(function(item) { item.remove(); });

        if (fields.length === 0) {
            emptyState.style.display = 'block';
            return;
        }

        emptyState.style.display = 'none';

        fields.forEach(function(field, index) {
            var item = createFieldElement(field, index);
            list.appendChild(item);
        });
    }

    function createFieldElement(field, index) {
        var div = document.createElement('div');
        div.className = 'df-field-item';
        div.setAttribute('data-index', index);
        div.setAttribute('draggable', 'true');

        var fieldTypeLabel = getOptionLabel(fieldTypes, field.field_type || 'text');
        var widthLabel = getOptionLabel(fieldWidths, field.width || 'full');

        div.innerHTML =
            '<div class="df-field-item-header">' +
                '<span class="df-drag-handle" title="Drag to reorder">&#9776;</span>' +
                '<div class="df-field-summary">' +
                    '<span class="df-label">' + escapeHtml(field.label || 'Untitled Field') + '</span>' +
                    '<span class="df-type-badge">' + escapeHtml(fieldTypeLabel) + '</span>' +
                    (field.is_required == 1 ? '<span class="df-required-badge">Required</span>' : '') +
                    '<span class="df-width-badge">' + escapeHtml(widthLabel) + '</span>' +
                '</div>' +
                '<div class="df-field-actions">' +
                    '<button type="button" class="df-toggle-btn" title="Edit">' +
                        '&#9998;' +
                    '</button>' +
                    '<button type="button" class="df-delete-btn" title="Delete">' +
                        '&#10005;' +
                    '</button>' +
                '</div>' +
            '</div>' +
            '<div class="df-field-detail" id="df-detail-' + index + '">' +
                createFieldForm(field, index) +
            '</div>';

        // Bind events
        var toggleBtn = div.querySelector('.df-toggle-btn');
        var header = div.querySelector('.df-field-item-header');
        var deleteBtn = div.querySelector('.df-delete-btn');
        var detail = div.querySelector('.df-field-detail');

        toggleBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            detail.classList.toggle('open');
        });

        header.addEventListener('click', function(e) {
            if (e.target.closest('.df-field-actions')) return;
            detail.classList.toggle('open');
        });

        deleteBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            if (confirm('Are you sure you want to delete this field?')) {
                fields.splice(index, 1);
                renderFields();
                updateFieldCount();
                syncToHiddenInput();
            }
        });

        // Drag events
        div.addEventListener('dragstart', function(e) {
            draggedItem = this;
            this.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
        });

        div.addEventListener('dragend', function() {
            this.classList.remove('dragging');
            draggedItem = null;
            // Reorder fields array based on DOM order
            reorderFieldsFromDom();
        });

        div.addEventListener('dragover', function(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            if (draggedItem && draggedItem !== this) {
                var list = document.getElementById('df-field-list');
                var items = Array.from(list.querySelectorAll('.df-field-item'));
                var draggedIdx = items.indexOf(draggedItem);
                var targetIdx = items.indexOf(this);
                if (draggedIdx < targetIdx) {
                    this.parentNode.insertBefore(draggedItem, this.nextSibling);
                } else {
                    this.parentNode.insertBefore(draggedItem, this);
                }
            }
        });

        // Bind input change events
        setTimeout(function() {
            bindFieldInputs(div, index);
        }, 0);

        return div;
    }

    function createFieldForm(field, index) {
        var isOptionType = optionFieldTypes.indexOf(field.field_type || 'text') !== -1;
        var options = field.options || [];
        if (typeof options === 'string') {
            try { options = JSON.parse(options); } catch(e) { options = []; }
        }
        if (!Array.isArray(options)) { options = []; }

        var validationRules = field.validation_rules || {};
        if (typeof validationRules === 'string') {
            try { validationRules = JSON.parse(validationRules); } catch(e) { validationRules = {}; }
        }

        var html =
            '<div class="df-field-row">' +
                '<div class="df-field-group">' +
                    '<label>Field Type</label>' +
                    '<select data-field="field_type" data-index="' + index + '">' +
                        fieldTypes.map(function(t) {
                            return '<option value="' + escapeAttr(t.value) + '"' + (field.field_type === t.value ? ' selected' : '') + '>' + escapeHtml(t.label) + '</option>';
                        }).join('') +
                    '</select>' +
                '</div>' +
                '<div class="df-field-group">' +
                    '<label>Label *</label>' +
                    '<input type="text" data-field="label" data-index="' + index + '" value="' + escapeAttr(field.label || '') + '" placeholder="Field label"/>' +
                '</div>' +
                '<div class="df-field-group">' +
                    '<label>Name (attribute)</label>' +
                    '<input type="text" data-field="name" data-index="' + index + '" value="' + escapeAttr(field.name || '') + '" placeholder="Auto-generated from label"/>' +
                '</div>' +
            '</div>' +
            '<div class="df-field-row">' +
                '<div class="df-field-group">' +
                    '<label>Required</label>' +
                    '<div class="df-toggle">' +
                        '<input type="checkbox" data-field="is_required" data-index="' + index + '"' + (field.is_required == 1 ? ' checked' : '') + '/>' +
                        '<span>This field is required</span>' +
                    '</div>' +
                '</div>' +
                '<div class="df-field-group">' +
                    '<label>Width</label>' +
                    '<select data-field="width" data-index="' + index + '">' +
                        fieldWidths.map(function(w) {
                            return '<option value="' + escapeAttr(w.value) + '"' + (field.width === w.value ? ' selected' : '') + '>' + escapeHtml(w.label) + '</option>';
                        }).join('') +
                    '</select>' +
                '</div>' +
                '<div class="df-field-group">' +
                    '<label>Sort Order</label>' +
                    '<input type="number" data-field="sort_order" data-index="' + index + '" value="' + (field.sort_order || index * 10) + '" min="0"/>' +
                '</div>' +
            '</div>' +
            '<button type="button" class="df-advanced-toggle" data-index="' + index + '">' +
                'Show Advanced Settings &#9660;' +
            '</button>' +
            '<div class="df-advanced-section" id="df-advanced-' + index + '">' +
                '<div class="df-field-row">' +
                    '<div class="df-field-group">' +
                        '<label>Placeholder</label>' +
                        '<input type="text" data-field="placeholder" data-index="' + index + '" value="' + escapeAttr(field.placeholder || '') + '"/>' +
                    '</div>' +
                    '<div class="df-field-group">' +
                        '<label>Default Value</label>' +
                        '<input type="text" data-field="default_value" data-index="' + index + '" value="' + escapeAttr(field.default_value || '') + '"/>' +
                    '</div>' +
                '</div>' +
                '<div class="df-field-row">' +
                    '<div class="df-field-group">' +
                        '<label>CSS Class</label>' +
                        '<input type="text" data-field="css_class" data-index="' + index + '" value="' + escapeAttr(field.css_class || '') + '" placeholder="e.g., custom-class"/>' +
                    '</div>' +
                    '<div class="df-field-group">' +
                        '<label>Validation Rules (JSON)</label>' +
                        '<textarea data-field="validation_rules" data-index="' + index + '">' + escapeHtml(typeof validationRules === 'object' ? JSON.stringify(validationRules) : String(validationRules || '')) + '</textarea>' +
                    '</div>' +
                '</div>' +
                '<div class="df-field-row">' +
                    '<div class="df-field-group">' +
                        '<label>Active</label>' +
                        '<div class="df-toggle">' +
                            '<input type="checkbox" data-field="is_active" data-index="' + index + '"' + (field.is_active != 0 ? ' checked' : '') + '/>' +
                            '<span>Field is active</span>' +
                        '</div>' +
                    '</div>' +
                '</div>' +
            '</div>' +
            '<div class="df-options-section" id="df-options-' + index + '" style="' + (isOptionType ? '' : 'display:none') + '">' +
                '<h4>Options (for dropdown, radio, checkbox, multiselect)</h4>' +
                '<div id="df-options-list-' + index + '">' +
                    options.map(function(opt, oi) {
                        var optLabel = typeof opt === 'object' ? (opt.label || '') : String(opt);
                        var optValue = typeof opt === 'object' ? (opt.value || '') : String(opt);
                        return '<div class="df-option-row">' +
                            '<input type="text" data-option-label="' + index + '" data-option-index="' + oi + '" value="' + escapeAttr(optLabel) + '" placeholder="Label"/>' +
                            '<input type="text" data-option-value="' + index + '" data-option-index="' + oi + '" value="' + escapeAttr(optValue) + '" placeholder="Value"/>' +
                            '<button type="button" onclick="window.dfRemoveOption(' + index + ',' + oi + ')">Remove</button>' +
                        '</div>';
                    }).join('') +
                '</div>' +
                '<button type="button" class="df-add-option-btn" onclick="window.dfAddOption(' + index + ')">+ Add Option</button>' +
            '</div>';

        return html;
    }

    function bindFieldInputs(container, index) {
        // Bind all input/select/textarea changes
        var inputs = container.querySelectorAll('[data-field]');
        inputs.forEach(function(input) {
            var fieldName = input.getAttribute('data-field');

            input.addEventListener('change', function() {
                updateFieldData(index, fieldName, this);
            });

            input.addEventListener('input', function() {
                updateFieldData(index, fieldName, this);
                // Auto-generate name from label
                if (fieldName === 'label') {
                    var nameInput = container.querySelector('[data-field="name"][data-index="' + index + '"]');
                    if (nameInput && !nameInput.dataset.manuallyEdited) {
                        nameInput.value = slugify(this.value);
                        fields[index].name = nameInput.value;
                    }
                }
                // Show/hide options section based on field type
                if (fieldName === 'field_type') {
                    var optSection = document.getElementById('df-options-' + index);
                    if (optSection) {
                        optSection.style.display = optionFieldTypes.indexOf(this.value) !== -1 ? '' : 'none';
                    }
                }
            });

            // Track manual edits to name field
            if (fieldName === 'name') {
                input.addEventListener('input', function() {
                    this.dataset.manuallyEdited = 'true';
                });
            }
        });

        // Bind advanced toggle
        var advToggle = container.querySelector('.df-advanced-toggle');
        if (advToggle) {
            advToggle.addEventListener('click', function() {
                var section = document.getElementById('df-advanced-' + index);
                if (section) {
                    section.classList.toggle('open');
                    this.innerHTML = section.classList.contains('open')
                        ? 'Hide Advanced Settings &#9650;'
                        : 'Show Advanced Settings &#9660;';
                }
            });
        }
    }

    function updateFieldData(index, fieldName, element) {
        if (!fields[index]) return;

        if (fieldName === 'is_required' || fieldName === 'is_active') {
            fields[index][fieldName] = element.checked ? 1 : 0;
        } else if (fieldName === 'validation_rules') {
            try {
                fields[index][fieldName] = JSON.parse(element.value || '{}');
            } catch(e) {
                fields[index][fieldName] = element.value;
            }
        } else {
            fields[index][fieldName] = element.value;
        }

        // Re-render header summary after changes
        var item = element.closest('.df-field-item');
        if (item) {
            var summary = item.querySelector('.df-field-summary');
            if (summary) {
                var f = fields[index];
                var fieldTypeLabel = getOptionLabel(fieldTypes, f.field_type || 'text');
                var widthLabel = getOptionLabel(fieldWidths, f.width || 'full');
                summary.innerHTML =
                    '<span class="df-label">' + escapeHtml(f.label || 'Untitled Field') + '</span>' +
                    '<span class="df-type-badge">' + escapeHtml(fieldTypeLabel) + '</span>' +
                    (f.is_required == 1 ? '<span class="df-required-badge">Required</span>' : '') +
                    '<span class="df-width-badge">' + escapeHtml(widthLabel) + '</span>';
            }
        }

        syncToHiddenInput();
    }

    function reorderFieldsFromDom() {
        var list = document.getElementById('df-field-list');
        var items = list.querySelectorAll('.df-field-item');
        var newFields = [];

        items.forEach(function(item) {
            var idx = parseInt(item.getAttribute('data-index'), 10);
            if (fields[idx]) {
                newFields.push(fields[idx]);
            }
        });

        fields = newFields;

        // Update sort orders
        fields.forEach(function(f, i) {
            f.sort_order = i * 10;
        });

        renderFields();
        updateFieldCount();
        syncToHiddenInput();
    }

    function bindAddButton() {
        document.getElementById('df-add-field-btn').addEventListener('click', function() {
            var newField = {
                _tempId: generateTempId(),
                field_type: 'text',
                label: '',
                name: '',
                placeholder: '',
                default_value: '',
                options: [],
                validation_rules: {},
                is_required: 0,
                css_class: '',
                width: 'full',
                sort_order: fields.length * 10,
                is_active: 1
            };

            fields.push(newField);
            renderFields();
            updateFieldCount();
            syncToHiddenInput();

            // Open the newly added field
            var lastDetail = document.getElementById('df-detail-' + (fields.length - 1));
            if (lastDetail) {
                lastDetail.classList.add('open');
                lastDetail.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    }

    function updateFieldCount() {
        var counter = document.getElementById('df-field-count');
        counter.textContent = fields.length + ' field' + (fields.length !== 1 ? 's' : '');
    }

    function syncToHiddenInput() {
        // Find the hidden input in the UI component form
        var attempts = 0;
        var trySync = function() {
            var hiddenInput = document.querySelector('input[name="fields_json"]');
            if (!hiddenInput) {
                hiddenInput = document.querySelector('[name="fields_json"]');
            }
            if (hiddenInput) {
                hiddenInput.value = JSON.stringify(fields);
                // Trigger change event for knockout/UI component awareness
                var event = new Event('change', { bubbles: true });
                hiddenInput.dispatchEvent(event);
            } else if (attempts < 10) {
                attempts++;
                setTimeout(trySync, 500);
            }
        };
        trySync();
    }

    // Global functions for option management
    window.dfAddOption = function(fieldIndex) {
        if (!fields[fieldIndex].options) {
            fields[fieldIndex].options = [];
        }
        if (!Array.isArray(fields[fieldIndex].options)) {
            fields[fieldIndex].options = [];
        }
        fields[fieldIndex].options.push({ label: '', value: '' });
        renderFields();
        updateFieldCount();
        syncToHiddenInput();

        // Keep the detail and options sections open
        var detail = document.getElementById('df-detail-' + fieldIndex);
        if (detail) detail.classList.add('open');
    };

    window.dfRemoveOption = function(fieldIndex, optionIndex) {
        if (fields[fieldIndex] && fields[fieldIndex].options) {
            fields[fieldIndex].options.splice(optionIndex, 1);
            renderFields();
            updateFieldCount();
            syncToHiddenInput();

            var detail = document.getElementById('df-detail-' + fieldIndex);
            if (detail) detail.classList.add('open');
        }
    };

    // Bind option input changes via event delegation
    document.addEventListener('input', function(e) {
        var el = e.target;
        if (el.hasAttribute('data-option-label')) {
            var fieldIdx = parseInt(el.getAttribute('data-option-label'), 10);
            var optIdx = parseInt(el.getAttribute('data-option-index'), 10);
            if (fields[fieldIdx] && fields[fieldIdx].options && fields[fieldIdx].options[optIdx]) {
                fields[fieldIdx].options[optIdx].label = el.value;
                // Auto-generate value from label
                var valueInput = document.querySelector('[data-option-value="' + fieldIdx + '"][data-option-index="' + optIdx + '"]');
                if (valueInput && !valueInput.dataset.manuallyEdited) {
                    valueInput.value = slugify(el.value);
                    fields[fieldIdx].options[optIdx].value = valueInput.value;
                }
                syncToHiddenInput();
            }
        }
        if (el.hasAttribute('data-option-value')) {
            var fieldIdx = parseInt(el.getAttribute('data-option-value'), 10);
            var optIdx = parseInt(el.getAttribute('data-option-index'), 10);
            if (fields[fieldIdx] && fields[fieldIdx].options && fields[fieldIdx].options[optIdx]) {
                el.dataset.manuallyEdited = 'true';
                fields[fieldIdx].options[optIdx].value = el.value;
                syncToHiddenInput();
            }
        }
    });

    function getOptionLabel(options, value) {
        for (var i = 0; i < options.length; i++) {
            if (options[i].value === value) return options[i].label;
        }
        return value;
    }

    function escapeHtml(str) {
        if (!str) return '';
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(String(str)));
        return div.innerHTML;
    }

    function escapeAttr(str) {
        if (!str) return '';
        return String(str).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // Initialize when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

    // Also hook into the form submission to ensure fields_json is synced
    document.addEventListener('submit', function() {
        syncToHiddenInput();
    }, true);
})();
</script>
