<script>
(function() {
    'use strict';

    var updateStatusUrl = '<?= $block->escapeJs($updateStatusUrl) ?>';
    var submissionId = <?= (int) $submission->getId() ?>;
    var formKey = '<?= $block->escapeJs($block->getFormKey()) ?>';

    function showMessage(type, text) {
        var msgEl = document.getElementById('df-status-message');
        msgEl.className = 'df-message ' + type;
        msgEl.textContent = text;
        setTimeout(function() {
            msgEl.className = 'df-message';
        }, 5000);
    }

    function sendUpdate(status, adminNotes) {
        var params = new URLSearchParams();
        params.append('submission_id', submissionId);
        params.append('form_key', formKey);
        if (status !== null) {
            params.append('status', status);
        }
        if (adminNotes !== null) {
            params.append('admin_notes', adminNotes);
        }

        fetch(updateStatusUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: params.toString()
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                showMessage('success', data.message || 'Updated successfully.');
                if (status !== null) {
                    // Update the status badge
                    var badge = document.querySelector('.df-status-badge');
                    if (badge) {
                        var colorMap = {
                            'new': '#1979c3',
                            'read': '#f0ad4e',
                            'replied': '#79a22e',
                            'closed': '#999999'
                        };
                        badge.style.background = colorMap[status] || '#333333';
                        badge.textContent = status.charAt(0).toUpperCase() + status.slice(1);
                    }
                }
            } else {
                showMessage('error', data.message || 'An error occurred.');
            }
        })
        .catch(function(err) {
            showMessage('error', 'Request failed: ' + err.message);
        });
    }

    document.getElementById('df-update-status-btn').addEventListener('click', function() {
        var status = document.getElementById('df-status-select').value;
        sendUpdate(status, null);
    });

    document.getElementById('df-save-notes-btn').addEventListener('click', function() {
        var notes = document.getElementById('df-admin-notes').value;
        sendUpdate(null, notes);
    });
})();
</script>
